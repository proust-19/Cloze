{
  "architecture": {
    "num_layers": 4,
    "hidden_dim": 256,
    "num_attention_heads": 8,
    "intermediate_dim": 1024,
    "max_sequence_length": 128,
    "vocab_size": 12000,
    "positional_embedding": "learned",
    "tie_mlm_head_to_embeddings": true,
    "hidden_dropout_prob": 0.1,
    "attention_dropout_prob": 0.1
  },
  "pretraining": {
    "epochs": 5,
    "target_corpus_size_mb": 25,
    "masking_probability": 0.15,
    "learning_rate": 5e-4,
    "weight_decay": 0.01,
    "warmup_ratio": 0.10,
    "lr_decay_strategy": "cosine",
    "seed": 42
  }
}